# Puerto donde escucha el servidor (Railway/Render lo inyectan automáticamente)
PORT=3010

# Ruta de la base de datos SQLite
# En Railway: montar volumen en /data y usar DB_PATH=/data/relay.db
# En local: DB_PATH=./relay.db
DB_PATH=./relay.db

# Secreto para registrar nuevas clínicas (cambiarlo antes de desplegar)
# Solo quien tenga este secreto puede crear una clínica nueva
REGISTRO_SECRET=cambia-esto-antes-de-desplegar
